/*
 * KarmaPad board definition
 * "If humans made it, I can do it too."
 */

#include <nordic/nrf52840_qiaa.dtsi>
#include "arduino_pro_micro_pins.dtsi"

/ {
    model = "KarmaPad";
    compatible = "1801collective,karmapad";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,display = &oled;
        zmk,kscan = &kscan0;
        zmk,underglow = &led_strip;
        zmk,battery = &vbatt;
    };

    // Direct-wire 6 keys (no matrix needed for 6 switches)
    kscan0: kscan_direct {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
        input-gpios
            = <&pro_micro 4  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K1 / F13
            , <&pro_micro 5  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K2 / F14
            , <&pro_micro 6  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K3 / F15
            , <&pro_micro 7  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K4 / F16
            , <&pro_micro 8  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K5 / F17
            , <&pro_micro 9  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K6 / F18
            , <&pro_micro 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K7 / Left encoder switch
            , <&pro_micro 14 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  // K8 / Right encoder switch
            ;
    };

    // LiPo battery voltage divider on pin P0.31
    vbatt: vbatt {
        compatible = "zmk,battery-voltage-divider";
        io-channels = <&adc 7>;
        output-ohms = <2000000>;
        full-ohms = <(2000000 + 820000)>;
    };
};

// ==================== I2C0 — SH1106 1.3" OLED ====================
&pro_micro_i2c {
    status = "okay";

    oled: ssd1306@3c {
        compatible = "sinowealth,sh1106";
        reg = <0x3c>;
        width = <128>;
        height = <64>;
        segment-offset = <2>;      // SH1106 offset — critical, don't change
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <63>;
        segment-remap;
        com-invdir;
        prechargep = <0x22>;
    };
};

// ==================== SPI0 — WS2812B underglow ====================
&pinctrl {
    spi3_default: spi3_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 6)>;   // Pro Micro pin 16 (MOSI)
        };
    };
    spi3_sleep: spi3_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 6)>;
            low-power-enable;
        };
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <10>;            // CHANGE to your LED count
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

&usbd {
    status = "okay";
};
