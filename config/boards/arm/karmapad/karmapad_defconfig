# KarmaPad defconfig
# "If humans made it, I can do it too."

if BOARD_KARMAPAD

config BOARD
    default "karmapad"

config ZMK_KEYBOARD_NAME
    default "KarmaPad"

# ---- BLE ----
config ZMK_BLE
    default y

config ZMK_USB
    default y

# ---- Display (OLED) ----
config ZMK_DISPLAY
    default y

config I2C
    default y

config SSD1306
    default y

# Use SH1106 compatible mode
config SSD1306_REVERSE_MODE
    default n

# ---- Underglow (WS2812B) ----
config ZMK_RGB_UNDERGLOW
    default y

config SPI
    default y

config WS2812_STRIP
    default y

config LED_STRIP
    default y

# Start underglow OFF to save battery — toggle via SETTINGS layer
config ZMK_RGB_UNDERGLOW_ON_START
    default n

config ZMK_RGB_UNDERGLOW_BRT_START
    default 40

# ---- Battery reporting ----
config ZMK_BATTERY_REPORTING
    default y

# ---- Sleep / power saving ----
config ZMK_SLEEP
    default y

config ZMK_IDLE_SLEEP_TIMEOUT
    default 900000   # 15 min

# ---- Encoder support ----
config EC11
    default y

config EC11_TRIGGER_GLOBAL_THREAD
    default y

endif # BOARD_KARMAPAD
